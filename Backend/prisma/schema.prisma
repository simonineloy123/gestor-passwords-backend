// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  createdAt     DateTime @default(now())

  // Relación 1 a N con PasswordRecord
  // Un usuario puede tener muchos registros de contraseña.
  passwordRecords PasswordRecord[]

  @@map("users") // Mapea el modelo a la tabla "users" en la BD
}

model PasswordRecord {
  id        String   @id @default(uuid())
  userId    String
  service   String
  username  String
  password  String
  category  String   @default("Otros")
  createdAt DateTime @default(now())

  // Relación N a 1 con User
  // Muchos registros de contraseña pertenecen a un solo usuario.
  // El campo 'userId' es la clave foránea.
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_records") // Mapea el modelo a la tabla "password_records"
}